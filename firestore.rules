rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPERS ───
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() &&
             get(/databases/$(database)/documents/config/admin).data.uid == request.auth.uid;
    }

    // ─── CONFIG (admin-only write, auth read) ───
    // Auth required for ALL config docs — including config/phones (master PIN
    // hashes live there). Drivers must signInAnonymously() before reading.
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /config/{parent}/list/{phoneId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── HELPERS: user ownership (admin-created docs have authUid field) ───
    function isOwnerOrLinked(userId) {
      return request.auth.uid == userId
             || (exists(/databases/$(database)/documents/users/$(userId))
                 && get(/databases/$(database)/documents/users/$(userId)).data.authUid == request.auth.uid);
    }

    // ─── USERS (IDs auto-generated by admin, don't match auth UIDs) ───
    match /users/{userId} {
      // Individual lookup remains permissive (clients sometimes need to fetch
      // a doc by id), but listing the full users collection is admin-only.
      allow get: if isAuth();
      allow list: if isAdmin();
      allow create, update: if isAuth() && (isOwnerOrLinked(userId) || isAdmin());
      allow delete: if isAdmin();

      // Subcollections: companies, destinations, config — owner, linked user, or admin
      match /{subcol}/{docId} {
        allow read: if isAuth() && (isOwnerOrLinked(userId) || isAdmin());
        allow create, update: if isAuth() && (isOwnerOrLinked(userId) || isAdmin());
        allow delete: if isAuth() && (isOwnerOrLinked(userId) || isAdmin());
      }
    }

    // ─── TICKETS (admin total; non-admin no puede tocar identidad ni facturación) ───
    match /tickets/{ticketId} {
      allow read: if isAuth();
      allow create: if isAuth();
      // Admin: full update. Non-admin auth (drivers / clients): blocked from
      // changing ownership and billing-sensitive fields.
      allow update: if isAdmin()
        || (isAuth()
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny([
                  'companyId', 'clientIdNum', 'uid', 'authUid',
                  'invoiceId', 'invoiceNum', 'invoiceRef',
                  'price', 'total', 'tariff', 'cod', 'shippingType',
                  'sender', 'senderAddress', 'senderPhone'
                ]));
      allow delete: if isAdmin();

      // ─── CHAT subcollection: per-ticket conversation between client,
      // driver and admin. Authed-only. Messages are immutable once sent
      // (admin can delete to moderate).
      match /chat/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() < 2000
          && request.resource.data.senderRole is string;
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ─── INVOICES — Inmutabilidad post-emisión (RD 1619/2012 art. 8) ───
    // Una factura emitida NO se modifica ni se borra: solo se rectifica
    // mediante factura rectificativa (abono). Admin puede:
    //   - crear nuevas facturas
    //   - actualizar SOLO campos no fiscales (paid, paidDate, notes_internas,
    //     sentToClient, lastReminderAt y similares)
    //   - delete: PROHIBIDO. Si hay un error → emitir abono rectificativo.
    match /invoices/{docId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin()
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny([
              'invoiceId', 'number', 'numero', 'serie',
              'date', 'invoiceDate', 'fechaDevengo',
              'subtotal', 'iva', 'irpf', 'total', 'baseImponible',
              'clientCIF', 'clientName', 'clientNIF', 'clientAddress',
              'advancedGrid', 'lines', 'concepto',
              'senderData', 'senderCIF', 'compId',
              'rectificaA', 'isAbono', 'tipoRectificacion', 'motivoRectificacion',
              'createdAt', 'createdBy'
            ]);
      allow delete: if false;
    }

    // ─── TARIFFS, ARTICLES, BILLING COMPANIES (admin-only write) ───
    match /tariffs/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /articles/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /billing_companies/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── PAPELERA (admin-only) ───
    // Tickets: borrado definitivo permitido (operacional, no fiscal)
    match /deleted_tickets/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    // Invoices y Abonos en papelera: NO se borran (conservación 4-6 años).
    // Solo se permite crear (al soft-delete) y leer/restaurar.
    match /deleted_invoices/{docId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }
    match /deleted_abonos/{docId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }
    match /deleted_users/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      // Subcoleccion espejada (companies, destinations) del cliente borrado
      match /{subcol}/{subDocId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
      }
    }

    // ─── CONTACTS — directorio unificado público (Gesco + NOVAPACK) ───
    // Solo campos publicos (nombre, NIF, dirección, teléfono).
    // Sin contraseñas/emails/IBANs/datos sensibles.
    match /contacts/{contactId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── SEPA MANDATE LOG — historial de cargos por mandato ───
    // Usado para determinar FRST (1er cargo) vs RCUR (recurrente) en remesas.
    // No se puede editar/borrar (auditoría inmutable).
    match /sepa_mandate_log/{docId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ─── BLACKLIST (auth read, admin write) ───
    match /deleted_erp_ids/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── MAILBOX (auth create/update, auth read, admin delete) ───
    match /mailbox/{docId} {
      allow create, update: if isAuth();
      allow read: if isAuth();
      allow delete: if isAdmin();
    }
    match /mailIncidencias/{docId} {
      allow create, update: if isAuth();
      allow read: if isAuth();
      allow delete: if isAdmin();
    }

    // ─── DRIVER: GPS live tracking (validate data structure + ownership) ───
    // docId in this collection is the driver's normalized phone, so we enforce
    // docId == data.phone to prevent a driver overwriting another driver's pin.
    match /driver_locations/{docId} {
      allow read: if isAuth();
      allow write: if isAuth()
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && request.resource.data.phone is string
        && docId == request.resource.data.phone
        && request.resource.data.phone.size() >= 6
        && request.resource.data.phone.size() <= 15;
    }

    // ─── DRIVER: route reassignments log (auth create, admin read/delete) ───
    match /driver_reassignments/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAdmin();
    }

    // ─── DRIVER: alerts (admin creates, drivers update, admin deletes) ───
    match /driver_alerts/{docId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }
    // ─── DRIVER: pickups (auth create/update, admin delete) ───
    match /pickupRequests/{docId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }
    // ─── DRIVER: cooper photos (auth create/update, admin delete) ───
    match /cooper_photos/{docId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ─── USER: notifications (auth read/create/update, admin delete) ───
    match /user_notifications/{docId} {
      allow read, create, update: if isAuth();
      allow delete: if isAdmin();
    }
    // ─── Destinations (legacy, auth read/create/update, admin delete) ───
    match /destinations/{docId} {
      allow read, create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ─── CONTABILIDAD: providers, expenses, journal (admin-only write) ───
    match /providers/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /expenses/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /journal/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── FACTURACIÓN AVANZADA ───
    match /adv_invoices/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /credit_notes/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── COMUNICACIONES ───
    match /campaigns/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── TICKET COUNTERS (atomic counter, validate increment by 1) ───
    match /ticket_counters/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth()
        && request.resource.data.currentMax is int
        && request.resource.data.currentMax == resource.data.currentMax + 1;
      allow delete: if isAdmin();
    }

    // ─── SEQUENCE COUNTERS (invoices_YYYY, journal, etc.) ───
    // Used by allocSequentialNumber() for atomic numbering. Same monotonic-by-1
    // discipline as ticket_counters; admin-only delete.
    match /sequence_counters/{docId} {
      allow read: if isAuth();
      allow create: if isAdmin()
        && request.resource.data.currentMax is int
        && request.resource.data.currentMax >= 1;
      allow update: if isAdmin()
        && request.resource.data.currentMax is int
        && request.resource.data.currentMax == resource.data.currentMax + 1;
      allow delete: if isAdmin();
    }

    // ─── DELIVERY ARCHIVE (immutable audit trail) ───
    match /delivery_archive/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ─── PUBLIC TICKETS (denormalized, safe-fields-only mirror for tracking) ───
    // Anyone with a ticket id can read its public tracking record (no PII like
    // sender data, prices, billing). Only authenticated callers can write — the
    // mirror is maintained by public_tickets_sync.js running in admin sessions.
    match /public_tickets/{docId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update: if isAuth()
        // Block obvious data leaks: never allow these fields in the public mirror
        && !request.resource.data.keys().hasAny([
              'price', 'total', 'tariff', 'cod', 'irpf', 'iva',
              'invoiceId', 'invoiceNum', 'invoiceRef',
              'senderPhone', 'senderAddress',
              'companyId', 'clientIdNum', 'uid', 'authUid',
              'clientName', 'clientCIF',
              'signatureURL', 'signatureMeta',
              'photoURL'
           ]);
      allow delete: if isAdmin();
    }
  }
}
