rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    
    // Permitir acceso de lectura publica a los recursos del proyecto si fueran necesarios
    // pero por ahora protegemos todo por defecto.
    
    // CHÓFERES - Firmas y fotos de entregas
    // Acceso autenticado (SMS, anónimo via master PIN, o email)
    // Limite: 10MB, solo imágenes
    match /deliveries/{deliveryId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // COOPER - Fotos de albaranes cooper
    // Usa {cooperPath=**} para aceptar cualquier profundidad bajo cooper/:
    //   cooper/recogida/foto.jpg                  (legacy 2 niveles)
    //   cooper/recogida/g123_abc/foto.jpg         (multi-foto: subcarpeta groupId)
    match /cooper/{cooperPath=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // INCIDENCIAS - Fotos de incidencias reportadas por repartidores
    match /incidents/{docId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // DISCREPANCIAS - Fotos de discrepancias en recogida (repartidor corrige items)
    match /discrepancies/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // PICKUP SIN ALBARÁN - Fotos de pre-albaranes generados por el repartidor
    match /pickup_no_doc/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // MANDATOS SEPA - PDFs firmados por el deudor (RD-Ley 19/2018, Reg UE 260/2012)
    // Limite 5MB. Solo PDF (la firma es legalmente válida como PDF). Solo admin escribe.
    match /sepa_mandates/{clientId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType == 'application/pdf';
    }

    // FACTURAS PDF - generadas para envío por email automático
    // Tamaño máx 10MB (facturas con muchas líneas). Solo PDF. Read auth (link va
    // en el correo). El mail_engine descarga vía URL pública firmada.
    match /invoices/{invoiceDocId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType == 'application/pdf';
    }

    // DENEGAR todo lo demas por seguridad
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
