# NOVAPACK CLOUD — backend env vars
# Copy this file to .env and fill in real values. Never commit .env to git.

# IMAP (mail engine)
IMAP_USER=administracion@novapack.info
IMAP_PASS=__ROTATE_AND_SET__
IMAP_HOST=imap.ionos.es
IMAP_PORT=993

# Firebase (mail_engine.js writes to Firestore as this user)
FIREBASE_API_KEY=__SET__
FIREBASE_AUTH_DOMAIN=novapack-68f05.firebaseapp.com
FIREBASE_PROJECT_ID=novapack-68f05
FIREBASE_ADMIN_EMAIL=administracion@novapack.info
FIREBASE_ADMIN_PASS=__ROTATE_AND_SET__

# ClickSend SMS (if invoked from a backend script)
CLICKSEND_USER=__SET__
CLICKSEND_API_KEY=__ROTATE_AND_SET__
